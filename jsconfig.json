{
	"compilerOptions": {
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"jsx": "react-jsx",
		"lib": ["ESNext", "DOM", "DOM.Iterable"],
		"allowJs": true,
		"checkJs": false,
		"skipLibCheck": true,
		"esModuleInterop": true,
		"allowSyntheticDefaultImports": true,
		"strict": false,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true,
		"isolatedModules": true,
		"noEmit": true,
		"paths": {
			"@/*": ["./src/*"],
			"@shared/*": ["./src/shared/*"],
			"@pages/*": ["./src/pages/*"],
			"@features/*": ["./src/features/*"],
			"@app/*": ["./src/app/*"],
			"@tests/*": ["./__tests__/*"],
			"@i18n/*": ["./src/i18n/*"],
			"@services/*": ["./src/services/*"]
		}
	},
	"include": ["src"],
	"exclude": ["node_modules", "dist", "build", "stats.html", "**/*.tsx"]
}
